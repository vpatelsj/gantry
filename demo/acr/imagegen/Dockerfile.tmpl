# Demo image generator template — substituted by 20-push-demo-image.sh.
#
# Goals:
#   - ~30 layers (DEMO_LAYER_COUNT) so containerd issues many distinct
#     blob GETs on a fresh node, exercising the ACR ReadOps limit.
#   - ~20 MiB / layer (DEMO_LAYER_BYTES) so total image ~600 MiB
#     compressed, exercising ACR egress.
#   - Layer digests differ between RUN_IDs even when DEMO_LAYER_COUNT
#     and DEMO_LAYER_BYTES are unchanged, so a fresh tag truly defeats
#     containerd's content-addressed cache. We achieve this by mixing
#     RUN_ID into every layer's payload via /dev/urandom seeded by
#     RUN_ID + layer_index.
#
# The substituted Dockerfile is built with `docker buildx build --push`,
# so we never need the resulting image locally.

# Use a tiny base; the demo doesn't care what runs in the container, only
# that the image is large.
FROM busybox:1.36

# RUN_ID is baked in as a label so the image is self-describing in ACR.
LABEL gantry.demo.run-id="${RUN_ID}"

# Place a marker so the workload can confirm what it's running.
RUN echo "RUN_ID=${RUN_ID}" > /run-id

# Layers: each `COPY layers/NN.bin /payload/NN.bin` is its own image
# layer with a content-addressed digest determined by the file bytes.
# 20-push-demo-image.sh fills layers/00.bin … layers/${N-1}.bin with
# RUN_ID-seeded random data BEFORE invoking buildx, guaranteeing each
# run produces a distinct set of layer digests.
${LAYER_COPY_LINES}

CMD ["/bin/sh", "-c", "echo POD_READY $(date -u +%FT%T.%NZ); cat /run-id; sleep 30"]
