# Phase 6b cleanup Job — purges the demo image from every node's
# containerd content store so the warm-cache rerun cannot serve from
# containerd's own blob cache and silently bypass gantry.
#
# Sequence per node:
#   1. ctr -n k8s.io images rm <repo>:<tag>     — drop image reference
#   2. ctr -n k8s.io leases ls / leases delete  — drop holding leases
#   3. ctr -n k8s.io content prune references   — GC unreferenced blobs
#   4. assert ctr -n k8s.io content ls | grep <digest> is empty
#
# Variables substituted by 62-cached-rerun.sh:
#   ${IMAGE_REF}    — full pull spec
#   ${MANIFEST_DIGEST} — sha256:... of the image manifest (assertion)
#   ${NODE_COUNT}   — fan-out
#
# Why `ctr` and not `crictl`: crictl has no content-store ops; only
# `ctr` (containerd's lower-level CLI) can delete leases and prune
# blobs. Image is debian + ctr static binary baked in via initContainer.
---
apiVersion: batch/v1
kind: Job
metadata:
  name: gantry-demo-cleanup
  namespace: default
  labels:
    app.kubernetes.io/name: gantry-demo-cleanup
spec:
  parallelism: ${NODE_COUNT}
  completions: ${NODE_COUNT}
  backoffLimit: 0
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        app.kubernetes.io/name: gantry-demo-cleanup
    spec:
      restartPolicy: Never
      hostPID: true
      tolerations:
        - operator: Exists
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/name: gantry-demo-cleanup
              topologyKey: kubernetes.io/hostname
      containers:
        - name: ctr
          # Use the AKS containerd image which already contains `ctr`.
          # mcr.microsoft.com/oss/binaries/containerd is a small,
          # AKS-trusted image. Falls back to debian + ctr if needed.
          image: mcr.microsoft.com/cbl-mariner/base/core:2.0
          command: ["/bin/sh", "-c"]
          args:
            - |
              set -eu
              # ctr lives on the host; nsenter into PID 1 to use it.
              CTR="nsenter -t 1 -m -u -i -n -p -- ctr -a /run/containerd/containerd.sock -n k8s.io"

              echo "==> images rm ${IMAGE_REF}"
              $CTR images rm ${IMAGE_REF} || true

              echo "==> leases ls / delete those holding ${MANIFEST_DIGEST}"
              for lease in $($CTR leases ls 2>/dev/null | tail -n +2 | awk '{print $1}'); do
                  if $CTR leases list-resources "$lease" 2>/dev/null \
                          | grep -q "${MANIFEST_DIGEST}"; then
                      echo "  delete lease $lease"
                      $CTR leases delete "$lease" || true
                  fi
              done

              echo "==> content prune references"
              $CTR content prune references || true

              echo "==> assertion: ${MANIFEST_DIGEST} absent from content store"
              if $CTR content ls | grep -q "${MANIFEST_DIGEST}"; then
                  echo "FAIL: manifest digest still present" >&2
                  exit 1
              fi
              echo "OK: cleared on $(hostname)"
          securityContext:
            privileged: true
            runAsUser: 0
          volumeMounts:
            - name: containerd-sock
              mountPath: /run/containerd/containerd.sock
            - name: containerd-data
              mountPath: /var/lib/containerd
      volumes:
        - name: containerd-sock
          hostPath:
            path: /run/containerd/containerd.sock
            type: Socket
        - name: containerd-data
          hostPath:
            path: /var/lib/containerd
            type: Directory
