# Sourceable configuration for the greenfield Azure demo setup.
# Use this as the template for deploy/demo/infra/env.local and edit the
# values that are specific to your subscription.

# Optional. Leave empty to use the currently selected az account.
export AZ_SUBSCRIPTION="110efc33-11a4-46b9-9986-60716283fbe7"

export AZ_LOCATION="canadacentral"
export AZ_RESOURCE_GROUP="gantry-demo-1"

# ACR names are globally unique, 5-50 chars, lowercase alphanumeric only.
# Edit this if the create step reports that the name is unavailable.
export ACR_NAME="gantrydemo$(printf '%s' "${USER:-user}" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9')"
export ACR_SKU="Standard"

export AKS_NAME="gantry-demo-1"
export AKS_NODE_COUNT="20"
export AKS_NODE_VM_SIZE="Standard_D4s_v5"
export AKS_NODE_OS_DISK_GB="128"
export AKS_NETWORK_PLUGIN="azure"

# Optional. Leave empty to let AKS choose the default supported version.
export AKS_KUBERNETES_VERSION=""

# Image build settings.
export IMAGE_PLATFORM="linux/amd64"
export IMAGE_TAG="demo"
export PROXY_IMAGE_REPO="acr-origin-proxy"
export GANTRY_IMAGE_REPO="gantry"
export BUILD_GANTRY_IMAGE="true"

# Kubernetes namespaces and Helm release names.
export GANTRY_DEMO_NAMESPACE="gantry-demo"
export MONITORING_NAMESPACE="monitoring"
export KPS_RELEASE="kps"
export GRAFANA_ADMIN_PASSWORD="gantry-demo"

# Proxy smoke target. The image build script pushes acr-origin-proxy:$IMAGE_TAG,
# which is a convenient small single-platform image for Phase 0.5 auth checks.
export PROXY_SMOKE_REPO="${PROXY_IMAGE_REPO}"
export PROXY_SMOKE_TAG="${IMAGE_TAG}"

# Destructive cleanup requires this explicit opt-in.
export CONFIRM_DESTROY="no"
